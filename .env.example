# Copy this file to .env and fill in your token.
#
# Run `claude setup-token` (needs a Claude Pro or Max subscription) and paste
# the token it prints below. This lets the demo run on your subscription
# instead of a metered API key.
CLAUDE_CODE_OAUTH_TOKEN=

# Note: if ANTHROPIC_API_KEY is set in your shell, it takes precedence over the
# token above. Run `unset ANTHROPIC_API_KEY` if you want to use the subscription.
